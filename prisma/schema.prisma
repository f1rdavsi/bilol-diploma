generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ROLE_ADMIN
  ROLE_MANAGER
  ROLE_MECHANIC
}

enum RepairStatus {
  NEW
  QUEUE
  DIAGNOSTICS
  IN_REPAIR
  WAITING_PARTS
  COMPLETED
  HANDED_OVER
}

model User {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  password       String
  role           UserRole      @default(ROLE_MECHANIC)
  assignedOrders RepairOrder[] @relation("AssignedOrders")
  statusChanges  RepairOrderStatusHistory[] @relation("OrderStatusChanges")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Client {
  id        Int           @id @default(autoincrement())
  fullName  String        @map("full_name")
  phone     String
  address   String?
  cars      Car[]
  orders    RepairOrder[]
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("clients")
}

model Car {
  id          Int           @id @default(autoincrement())
  clientId    Int           @map("client_id")
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brand       String
  model       String
  year        Int
  vin         String        @unique
  plateNumber String        @unique @map("plate_number")
  orders      RepairOrder[]
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("cars")
}

model RepairOrder {
  id                 Int          @id @default(autoincrement())
  clientId           Int          @map("client_id")
  carId              Int          @map("car_id")
  employeeId         Int?         @map("employee_id")
  client             Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  car                Car          @relation(fields: [carId], references: [id], onDelete: Restrict)
  employee           User?        @relation("AssignedOrders", fields: [employeeId], references: [id], onDelete: SetNull)
  statusHistory      RepairOrderStatusHistory[]
  problemDescription String       @db.Text @map("problem_description")
  status             RepairStatus @default(NEW)
  price              Decimal      @default(0) @db.Decimal(10, 2)
  queuePosition      Int          @default(0) @map("queue_position")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@index([status, queuePosition])
  @@map("repair_orders")
}

model RepairOrderStatusHistory {
  id            Int          @id @default(autoincrement())
  repairOrderId Int          @map("repair_order_id")
  repairOrder   RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  changedById   Int?         @map("changed_by_id")
  changedBy     User?        @relation("OrderStatusChanges", fields: [changedById], references: [id], onDelete: SetNull)
  fromStatus    RepairStatus? @map("from_status")
  toStatus      RepairStatus  @map("to_status")
  note          String?      @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([repairOrderId, createdAt])
  @@map("repair_order_status_history")
}

model Service {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  short       String   @db.VarChar(500)
  description String   @db.Text
  price       Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("TJS") @db.VarChar(8)
  image       String   @db.VarChar(1000)
  icon        String   @default("Wrench") @db.VarChar(80)
  benefits    Json
  steps       Json
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("services")
}

model ServiceRequest {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  car         String?
  message     String?  @db.Text
  serviceSlug String?  @map("service_slug")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("service_requests")
}
